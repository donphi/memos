# ============================================================================
# MEMOS ROUTER - ENVIRONMENT VARIABLES
# Copy this file to .env and fill in the values.
# Version pins mirror config/versions.yaml — keep them in sync.
# ============================================================================

# ---- Version Pins (from config/versions.yaml) ----
MEMOS_VERSION=0.26.1
PYTHON_VERSION=3.12-slim
POSTGRES_VERSION=16-alpine

# ---- Domains (for Caddy HTTPS) ----
# Both domains must point to THIS server's IP (same A record, same IP).
# Caddy routes traffic to the correct container based on the domain name.
MEMOS_DOMAIN=memos.yourdomain.com
ROUTER_DOMAIN=router.yourdomain.com

# ---- Memos Server ----
MEMOS_PORT=5230
MEMOS_API_TOKEN=your_memos_api_token_here
MEMOS_DATA_DIR=/opt/memos/data    # Host path for Memos data (bind mount) --previous hetzner setup

# ---- Category Memo ----
# Run: docker compose exec api python scripts/seed_categories.py
# Then paste the printed UID here
CATEGORY_MEMO_UID=

# ---- Database ----
POSTGRES_PASSWORD=change_this_to_a_secure_password
DB_PORT=5432

# For external database (Supabase, Railway, etc), uncomment and set:
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ---- API Router ----
ROUTER_PORT=8780

# ---- LLM (optional) ----
LLM_API_KEY=
LLM_CLASSIFY_ENABLED=false
# LLM_BASE_URL=https://openrouter.ai/api/v1
